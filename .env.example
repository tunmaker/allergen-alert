# Raspberry Pi Configuration
PI_HOSTNAME=rpi-air-quality-01
DEVICE_ID=rpi_main

# MQTT Broker Configuration
MQTT_BROKER_HOST=mqtt.proxmox.local
MQTT_BROKER_PORT=8883
MQTT_USERNAME=rpi_sensor
MQTT_PASSWORD=your_secure_password_here

# MQTT TLS Configuration
MQTT_TLS_CA_CERT=/etc/allergen-alert/certs/ca.crt
MQTT_TLS_CERTFILE=/etc/allergen-alert/certs/client.crt
MQTT_TLS_KEYFILE=/etc/allergen-alert/certs/client.key
MQTT_TLS_VERSION=tlsv1_2

# Home Assistant MQTT Discovery
HA_DISCOVERY_PREFIX=homeassistant
HA_MQTT_TOPIC_PREFIX=home/rpi_aq

# Sensor Configuration
I2C_BUS=1

# PMS5003 UART Configuration
PMS5003_UART_PORT=/dev/ttyAMA0
PMS5003_BAUDRATE=9600

# Temperature Sensor Offsets (degrees Celsius)
BME680_TEMP_OFFSET=0
SCD40_TEMP_OFFSET=0
AHT21_TEMP_OFFSET=0

# Data Publishing Intervals (seconds)
SIMPLE_SENSOR_INTERVAL=300
AIR_QUALITY_SENSOR_INTERVAL=60
PM_SENSOR_INTERVAL=300
SOUND_SENSOR_INTERVAL=60

# ENS160 Configuration
ENS160_BURN_IN_HOURS=1
ENS160_FULL_ACCURACY_DAYS=7

# PMS5003 Duty Cycle Configuration
PMS5003_DUTY_CYCLE_ENABLED=true
PMS5003_DUTY_CYCLE_ON_SECONDS=30
PMS5003_DUTY_CYCLE_OFF_SECONDS=30

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/var/log/allergen-alert.log

# Optional: Home Assistant REST API (for advanced automations)
HA_API_URL=http://192.168.1.100:8123
HA_API_TOKEN=your_long_lived_token_here
